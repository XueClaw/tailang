{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tailang.org/schemas/tai.schema.json",
  "title": "Tailang .tai Schema",
  "description": "Canonical JSON schema for Tailang .tai intermediate representation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "source",
    "modules",
    "code_blocks",
    "unresolved_items"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Schema or IR version."
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "modules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/module"
      }
    },
    "code_blocks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/codeBlock"
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/unresolvedItem"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "model",
        "temperature"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1,
          "description": "LLM provider name such as dashscope, ollama, or custom."
        },
        "model": {
          "type": "string",
          "minLength": 1,
          "description": "Model identifier used during precompile."
        },
        "temperature": {
          "type": "string",
          "minLength": 1,
          "description": "Temperature captured as string for stable serialization."
        }
      }
    },
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "functions"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "functions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/function"
          }
        }
      }
    },
    "function": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "params",
        "description",
        "validations"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "params": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "description": {
          "type": "string"
        },
        "validations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "codeBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "language",
        "code"
      ],
      "properties": {
        "language": {
          "type": "string",
          "minLength": 1
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "linked_to": {
          "type": "string"
        }
      }
    },
    "unresolvedItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "description"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
